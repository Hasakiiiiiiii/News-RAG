<mxfile host="app.diagrams.net">
  <diagram name="News Crawler Architecture">
    <mxGraphModel dx="1000" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="scrapy" value="Scrapy Spider&#xa;(VNExpress, TuoiTre, DanTri)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="kafka" value="Kafka Topic&#xa;news_raw" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="350" y="120" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="cleaning" value="Cleaning Service&#xa;(Parser NLP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="350" y="220" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="postgres" value="PostgreSQL&#xa;cleaned_news" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="350" y="320" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="embedding" value="Embedding Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="350" y="420" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="vector" value="Vector DB&#xa;(Qdrant / Milvus)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="350" y="520" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="api" value="Search API&#xa;(FastAPI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="350" y="620" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="scrapy" target="kafka">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="kafka" target="cleaning">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="cleaning" target="postgres">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="postgres" target="embedding">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="embedding" target="vector">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e6" edge="1" parent="1" source="vector" target="api">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>